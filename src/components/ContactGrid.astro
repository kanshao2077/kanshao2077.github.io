---
import { contactLinks, type Lang } from "../data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const emailLink = contactLinks.find((link) => link.icon === "email");
const platformLinks = contactLinks.filter((link) => link.icon !== "email");
---

<div class="contact-grid">
  {platformLinks.map((link) => (
    <a
      class:list={["contact-card", `tone-${link.icon}`]}
      href={link.href}
      target="_blank"
      rel="noreferrer"
    >
      <span class="contact-icon" aria-hidden="true">
        {link.icon === "bilibili" && (
          <svg viewBox="0 0 24 24">
            <path d="M7 7h10a3 3 0 0 1 3 3v5a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-5a3 3 0 0 1 3-3Z" />
            <path d="m8 4 2 3M16 4l-2 3M9 12h.01M15 12h.01M10 15h4" />
          </svg>
        )}
        {link.icon === "github" && (
          <svg viewBox="0 0 24 24">
            <path d="M12 .7a11.3 11.3 0 0 0-3.6 22c.6.1.8-.2.8-.6v-2c-3.3.7-4-1.4-4-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11 11 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.2c0 .4.2.7.8.6A11.3 11.3 0 0 0 12 .7Z" />
          </svg>
        )}
        {link.icon === "x" && <span class="logo-letter">X</span>}
        {link.icon === "xiaohongshu" && <span class="logo-letter logo-letter-cn">小红书</span>}
        {link.icon === "wechat" && (
          <svg viewBox="0 0 24 24">
            <path d="M10.5 6C6.9 6 4 8.3 4 11.2c0 1.6.9 3 2.3 4l-.6 2 2.2-1.1c.8.2 1.7.4 2.6.4 3.6 0 6.5-2.3 6.5-5.2S14.1 6 10.5 6Z" />
            <path d="M14.4 11.4c3.1.2 5.6 2.1 5.6 4.6 0 1.3-.7 2.5-1.9 3.3l.5 1.7-1.9-.9c-.7.2-1.4.3-2.3.3-2.9 0-5.3-1.7-5.8-4" />
          </svg>
        )}
        {link.icon === "jike" && <span class="logo-letter">J</span>}
        {link.icon === "douban" && <span class="logo-letter">豆</span>}
        {link.icon === "sspai" && <span class="logo-letter">π</span>}
      </span>
      <span class="contact-card-copy">
        <strong>{link.name[lang]}</strong>
      </span>
      <em>{link.action[lang]}</em>
    </a>
  ))}
</div>

{emailLink && (
  <a class="contact-card contact-email-card tone-email" href={emailLink.href}>
    <span class="contact-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M3 6.5h18v11H3z" />
        <path d="m4 7 8 6 8-6" />
      </svg>
    </span>
    <span class="contact-card-copy">
      <strong>{emailLink.handle}</strong>
      <span>{emailLink.name[lang]}</span>
    </span>
    <em>{emailLink.action[lang]}</em>
  </a>
)}
