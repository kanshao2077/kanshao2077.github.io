---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionPixelNav from "../components/SectionPixelNav.astro";
import Timeline from "../components/Timeline.astro";
import WorkGrid from "../components/WorkGrid.astro";
import { copy, skills } from "../data/site";

const lang = "zh";
const t = copy[lang];
const sectionNav = [
  { id: "intro", label: "开场" },
  { id: "positioning", label: "定位" },
  { id: "selected", label: "作品" },
  { id: "experience", label: "经历" },
  { id: "capability", label: "能力" },
  { id: "now", label: "现在" },
  { id: "gallery-preview", label: "图像" },
];
---

<BaseLayout lang={lang} path="/">
  <SectionPixelNav sections={sectionNav} />

  <section id="intro" class="hero-section section-pad">
    <div class="hero-rays" aria-hidden="true"></div>
    <div class="hero-copy">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1>{t.hero.name}</h1>
      <p class="hero-title">{t.hero.title}</p>
      <p class="hero-intro">{t.hero.intro}</p>
      <div class="hero-actions">
        <a class="button primary" href="/works">{t.hero.primaryCta}</a>
        <a class="button secondary" href="/contact">{t.hero.secondaryCta}</a>
      </div>
    </div>
    <div class="hero-showcase computer-showcase" aria-label="复古未来主义电脑主视觉">
      <img src="/images/retro-computer-hero.png" alt="蓝白黑复古未来主义电脑插图" decoding="async" fetchpriority="high" />
    </div>
  </section>

  <section id="positioning" class="proof-band">
    <div>
      <p class="eyebrow">Positioning</p>
      <h2>{t.home.proofTitle}</h2>
    </div>
    <p>{t.home.proofBody}</p>
  </section>

  <section id="selected" class="section-pad">
    <div class="section-heading">
      <p class="eyebrow">Selected</p>
      <h2>{t.home.featuredTitle}</h2>
      <a class="text-link" href="/works">View all</a>
    </div>
    <WorkGrid lang={lang} featuredOnly />
  </section>

  <section id="experience" class="split-section section-pad">
    <div>
      <p class="eyebrow">Experience</p>
      <h2>{t.home.timelineTitle}</h2>
    </div>
    <Timeline lang={lang} compact />
  </section>

  <section id="capability" class="section-pad">
    <div class="section-heading">
      <p class="eyebrow">Capability</p>
      <h2>{t.home.capabilitiesTitle}</h2>
    </div>
    <div class="capability-grid">
      {t.home.capabilities.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
    <div class="tag-cloud">
      {skills[lang].map((skill) => <span>{skill}</span>)}
    </div>
  </section>

  <section id="now" class="currently-band">
    <div>
      <p class="eyebrow">Now</p>
      <h2>{t.home.currentlyTitle}</h2>
    </div>
    <ul>
      {t.home.currently.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section id="gallery-preview" class="gallery-entry section-pad">
    <div>
      <p class="eyebrow">Visual Taste</p>
      <h2>{t.home.galleryTitle}</h2>
      <p>{t.home.galleryBody}</p>
      <a class="button secondary" href="/gallery">Open Gallery</a>
    </div>
    <div class="gallery-placeholder" aria-label="Gallery preview">
      <img src="/images/gallery-preview-01.jpg" alt="" loading="lazy" decoding="async" />
      <img src="/images/gallery-preview-02.jpg" alt="" loading="lazy" decoding="async" />
      <img src="/images/gallery-preview-03.jpg" alt="" loading="lazy" decoding="async" />
      <img src="/images/gallery-preview-04.jpg" alt="" loading="lazy" decoding="async" />
    </div>
  </section>
</BaseLayout>
