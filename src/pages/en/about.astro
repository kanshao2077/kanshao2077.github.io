---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Timeline from "../../components/Timeline.astro";
import { copy, skills } from "../../data/site";

const lang = "en";
const t = copy[lang].aboutPage;
---

<BaseLayout lang={lang} path="/about" title={t.title}>
  <section class="page-hero page-hero--profile section-pad">
    <p class="eyebrow">Profile</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <section class="about-grid section-pad top-tight">
    <div class="about-card">
      <h2>Profile</h2>
      <p>{t.bio}</p>
      <div class="tag-cloud">
        {skills[lang].map((skill) => <span>{skill}</span>)}
      </div>
    </div>
    <div class="about-card tone-card">
      <h2>{t.noteTitle}</h2>
      <p>{t.note}</p>
    </div>
  </section>

  <section class="section-pad top-tight">
    <div class="section-heading">
      <p class="eyebrow">Experience</p>
      <h2>{t.timelineTitle}</h2>
    </div>
    <Timeline lang={lang} />
  </section>
</BaseLayout>
