---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactGrid from "../components/ContactGrid.astro";
import { copy } from "../data/site";

const lang = "zh";
const t = copy[lang].contactPage;
---

<BaseLayout lang={lang} path="/contact" title={t.title} hideFooter>
  <section class="page-hero section-pad compact">
    <p class="eyebrow">Connect</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <section class="contact-layout section-pad top-tight">
    <ContactGrid lang={lang} />
  </section>
</BaseLayout>
